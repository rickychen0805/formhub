// ── Boot ──
const app = document.getElementById('app');
(async () => {
  await initFirebase();
  S.loading = true; render();
  const [forms, depts, flows] = await Promise.all([Cloud.getForms(), Cloud.getDepts(), Cloud.getFlows()]);
  S.forms = forms; S.depts = depts; S.flows = flows;
  if (!forms.length) {
    await Cloud.saveCounters({PUR:3,SAL:1,HR:1,WH:1});
    const samples = [
      {id:'f_local_001',deptId:'PUR',seq:'PUR-2026-001',ver:2,applicant:'王大明',date:'2026-01-15',status:'approved',
       fields:{f1:'立即科技股份有限公司',f2:'IT設備',f3:'175000',f4:'年度採購'},
       items:[{id:'i1',name:'筆記型電腦',qty:5,unit:'台',price:35000}],
       approvals:[{step:0,role:'部門主管',name:'張主管',status:'approved',time:'2026-01-17 10:30',comment:'同意'}],
       history:[{ver:'v1',who:'王大明',time:'2026-01-15 09:00',reason:'初次建立',changes:[]},{ver:'v2',who:'王大明',time:'2026-01-16 14:00',reason:'廠商名稱更正',changes:[{field:'廠商名稱',old:'立即科技',new:'立即科技股份有限公司'}]}]},
      {id:'f_local_002',deptId:'PUR',seq:'PUR-2026-002',ver:1,applicant:'李小花',date:'2026-03-01',status:'pending',
       fields:{f1:'台灣大哥大',f2:'服務',f3:'13980',f4:'門號續約'},
       items:[{id:'i1',name:'商務門號',qty:20,unit:'門',price:699}],
       approvals:[{step:0,role:'部門主管',name:'',status:'pending',time:null,comment:''}],
       history:[{ver:'v1',who:'李小花',time:'2026-03-01 11:00',reason:'初次建立',changes:[]}]}
    ];
    for (const f of samples) await Cloud.saveForm(f);
    S.forms = await Cloud.getForms();
  }
  S.loading = false; render();
  if (firebaseReady) {
    onSnapshot(collection(db,'forms'), snap => {
