function fieldInput(id, fd, val='') {
  switch(fd.type) {
    case 'number':   return `<input type="number" id="${id}" value="${val}" placeholder="0">`;
    case 'date':     return `<input type="date" id="${id}" value="${val}">`;
    case 'textarea': return `<textarea id="${id}" placeholder="${fd.label}...">${val}</textarea>`;
    case 'select': { const opts=(fd.options||'').split(',').map(o=>o.trim()).filter(Boolean);
      return `<select id="${id}"><option value="">請選擇...</option>${opts.map(o=>`<option${o===val?' selected':''}>${o}</option>`).join('')}</select>`; }
    default: return `<input type="text" id="${id}" value="${val}" placeholder="${fd.label}">`;
  }
}

// ── Navigation ──
function go(p) { S.page=p; S.sidebar=false; window.scrollTo(0,0); render(); }
function goDept(id) { S.page='all-forms'; S.deptFilter=id; S.sidebar=false; render(); }
function goForm(id) { S.formId=id; S.page='form-view'; window.scrollTo(0,0); render(); }
function goApprove(id) { S.formId=id; S.page='approve'; window.scrollTo(0,0); render(); }

function toast(msg, d=2500) {
  const el=document.getElementById('toast'); if(!el) return;
  el.textContent=msg; el.classList.add('show');
  clearTimeout(el._t); el._t=setTimeout(()=>el.classList.remove('show'),d);
}

// ── Sub-table helpers ──
let rowN = 1;
function addRow() {
  rowN++;
  const tbody = document.getElementById('items-body'); if (!tbody) return;
  const tr = document.createElement('tr'); tr.id='item-row-'+rowN;
  tr.innerHTML=`<td><input type="text" placeholder="品名"></td>
    <td><input type="number" value="1" min="1" oninput="subUp(this)"></td>
    <td><input type="text" value="個"></td>
    <td><input type="number" value="0" min="0" oninput="subUp(this)"></td>
    <td id="sub-${rowN}" class="text-muted text-xs">NT$ 0</td>
    <td><button class="btn btn-sm btn-danger" onclick="rmRow(this)">✕</button></td>`;
  tbody.appendChild(tr);
}
function rmRow(btn) { btn.closest('tr').remove(); reTot(); }
function subUp(input) {
  const row=input.closest('tr'), ins=row.querySelectorAll('input[type=number]');
  const s=Number(ins[0]?.value||0)*Number(ins[1]?.value||0);
  const c=row.querySelector('td:nth-child(5)'); if(c) c.textContent=fmt(s);
  reTot();
}
function reTot() {
  let t=0; document.querySelectorAll('#items-body tr').forEach(tr=>{
    const ins=tr.querySelectorAll('input[type=number]');
    if(ins.length>=2) t+=Number(ins[0].value||0)*Number(ins[1].value||0);
  });
  const el=document.getElementById('items-total'); if(el) el.textContent=fmt(t);
}
function collectRows() {
  const items=[];
  document.querySelectorAll('#items-body tr').forEach((tr,i)=>{
    const ins=tr.querySelectorAll('input');
    if(ins.length>=4&&ins[0].value.trim())
      items.push({id:'i'+(i+1),name:ins[0].value.trim(),qty:Number(ins[1].value)||1,unit:ins[2].value||'個',price:Number(ins[3].value)||0});
  });
  return items;
}

// ── Async actions ──
async function doSave(status) {
  const deptId = document.getElementById('new-dept')?.value;
  const applicant = document.getElementById('new-applicant')?.value?.trim();
  if (!applicant) { toast('請填寫申請人'); return; }
  const dept = S.depts.find(d=>d.id===deptId); if (!dept) return;
  const fields={};
  for (const fd of dept.fields||[]) {
    const el=document.getElementById('nf-'+fd.id);
    if (fd.required&&(!el||!el.value.trim())) { toast(`請填寫「${fd.label}」`); return; }
    if (el) fields[fd.id]=el.value;
  }
  const seq = await genSeq(deptId);
  const flowDef = S.flows[deptId]||[];
  const form = { id:'f_local_'+Date.now(), deptId, seq, ver:1, applicant, date:today(), status, fields, items:collectRows(),
    approvals: status==='pending'?flowDef.map((s,i)=>({step:i,role:s.role,userId:s.userId,name:'',status:i===0?'pending':'waiting',time:null,comment:''})):[],
    history:[{ver:'v1',who:applicant,time:now(),reason:'初次建立',changes:[]}] };
  toast('儲存中...', 8000);
  try {
    const saved = await Cloud.saveForm(form);
    S.forms = await Cloud.getForms();
    toast(status==='draft'?'已儲存草稿':'已送出審核');
    goForm(saved.id);
  } catch { toast('儲存失敗'); }
}

async function doEdit(id) {
  const who=document.getElementById('edit-who')?.value?.trim();
  const reason=document.getElementById('edit-reason')?.value?.trim();
  if (!who||!reason) { toast('請填寫修改人與修改原因'); return; }
  const f={...S.forms.find(x=>x.id===id)}; f.fields={...f.fields};
  const dept=S.depts.find(d=>d.id===f.deptId)||{};
  const changes=[];
  for (const fd of dept.fields||[]) {
    const el=document.getElementById('ef-'+fd.id);
    if (el&&el.value!==(f.fields?.[fd.id]||'')) {
      changes.push({field:fd.label,old:f.fields?.[fd.id]||'（空）',new:el.value});
      f.fields[fd.id]=el.value;
    }
  }
  const ni=collectRows();
  if (JSON.stringify(ni)!==JSON.stringify(f.items)) { changes.push({field:'品項',old:`${f.items?.length||0}項`,new:`${ni.length}項`}); f.items=ni; }
  f.ver=(f.ver||1)+1;
  f.history=[...(f.history||[]),{ver:'v'+f.ver,who,time:now(),reason,changes}];
  toast('儲存中...', 8000);
  try { await Cloud.saveForm(f); S.forms=await Cloud.getForms(); toast('修訂已儲存（v'+f.ver+'）'); goForm(id); }
  catch { toast('儲存失敗'); }
}

async function doReview(id) {
  const f={...S.forms.find(x=>x.id===id)};
  const flowDef=S.flows[f.deptId]||[];
  f.status='pending';
  f.approvals=flowDef.map((s,i)=>({step:i,role:s.role,userId:s.userId,name:'',status:i===0?'pending':'waiting',time:null,comment:''}));
  f.history=[...(f.history||[]),{ver:'v'+(f.ver||1),who:f.applicant,time:now(),reason:'送出審核',changes:[{field:'狀態',old:'草稿',new:'審核中'}]}];
  await Cloud.saveForm(f); S.forms=await Cloud.getForms();
  toast('已送出審核'); goForm(id);
}

async function doApprove(id) {
  const who=document.getElementById('ap-who')?.value?.trim();
  const decision=document.getElementById('ap-decision')?.value;
  const comment=document.getElementById('ap-comment')?.value?.trim();
  if (!who) { toast('請填寫審核人'); return; }
  const f={...S.forms.find(x=>x.id===id)}; f.approvals=[...(f.approvals||[])];
  const idx=f.approvals.findIndex(a=>a.status==='pending');
  if (idx>=0) f.approvals[idx]={...f.approvals[idx],status:decision,name:who,time:now(),comment};
  const allOk=f.approvals.every(a=>a.status==='approved');
  const hasRej=f.approvals.some(a=>a.status==='rejected');
  if (hasRej) { f.status='rejected'; f.history=[...(f.history||[]),{ver:'v'+(f.ver||1),who,time:now(),reason:comment||'退回',changes:[{field:'狀態',old:'審核中',new:'已退回'}]}]; }
  else if (allOk) { f.status='approved'; f.history=[...(f.history||[]),{ver:'v'+(f.ver||1),who,time:now(),reason:'全部核准',changes:[{field:'狀態',old:'審核中',new:'已核准'}]}]; }
  else { const nx=f.approvals.find(a=>a.status==='waiting'); if(nx) nx.status='pending'; }
  await Cloud.saveForm(f); S.forms=await Cloud.getForms();
  toast(decision==='approved'?'✓ 已核准':'✗ 已退回'); goForm(id);
}

async function addField(deptId) {
  const dept=S.depts.find(d=>d.id===deptId); if(!dept) return;
  dept.fields=[...(dept.fields||[]),{id:'f'+Date.now(),label:'新欄位',type:'text',required:false}];
  await Cloud.saveDepts(S.depts); toast('欄位已新增'); render();
}
async function delField(deptId,fid) {
  if(!confirm('確定刪除此欄位？')) return;
  const dept=S.depts.find(d=>d.id===deptId); if(!dept) return;
  dept.fields=(dept.fields||[]).filter(f=>f.id!==fid);
  await Cloud.saveDepts(S.depts); toast('已刪除'); render();
}
async function updField(deptId,fid,key,val) {
  const dept=S.depts.find(d=>d.id===deptId), field=(dept?.fields||[]).find(f=>f.id===fid);
  if(field) { field[key]=val; await Cloud.saveDepts(S.depts); if(key==='type') render(); }
}
async function addFlow(deptId) {
  S.flows[deptId]=[...(S.flows[deptId]||[]),{role:'審核人',userId:''}];
  await Cloud.saveFlows(S.flows); toast('已新增'); render();
}
async function delFlow(deptId,idx) {
  S.flows[deptId]=(S.flows[deptId]||[]).filter((_,i)=>i!==idx);
  await Cloud.saveFlows(S.flows); toast('已刪除'); render();
}
async function updFlow(deptId,idx,key,val) {
  if(S.flows[deptId]?.[idx]) { S.flows[deptId][idx][key]=val; await Cloud.saveFlows(S.flows); }
}
async function saveDept() {
  const name=document.getElementById('m-name')?.value?.trim();
  const prefix=document.getElementById('m-prefix')?.value?.trim().toUpperCase();
  const color=document.getElementById('m-color')?.value;
  if(!name||!prefix) { toast('請填寫部門名稱與前綴代碼'); return; }
  if(S.depts.find(d=>d.id===prefix)) { toast('前綴代碼已存在'); return; }
  S.depts.push({id:prefix,name,color,prefix,fields:[{id:'f1',label:'說明',type:'textarea',required:false}]});
  await Cloud.saveDepts(S.depts);
  const c=await Cloud.getCounters(); c[prefix]=1; await Cloud.saveCounters(c);
  S.modal=null; toast(`${name} 已新增`); render();
}

function pwaBanner() {
  if(window.matchMedia('(display-mode: standalone)').matches) return;
  if(Local.get('pwa-dismissed')) return;
  const main=document.querySelector('.main'); if(!main) return;
  if(main.querySelector('.pwa-banner')) return;
  const isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent);
  const b=document.createElement('div'); b.className='pwa-banner';
  b.innerHTML=isIOS
    ?`<span>點 Safari「分享」→「加入主畫面」即可安裝</span><span style="margin-left:auto;cursor:pointer;padding:4px;" onclick="this.parentNode.remove();Local.set('pwa-dismissed',1)">✕</span>`
    :`<span>可加入主畫面，像 APP 使用（免下載）</span><span style="margin-left:auto;cursor:pointer;padding:4px;" onclick="this.parentNode.remove();Local.set('pwa-dismissed',1)">✕</span>`;
  main.prepend(b);
}
