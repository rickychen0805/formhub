  return `<div>
    <div class="page-header"><h1 class="page-title">總覽</h1></div>
    ${!firebaseReady?`<div class="pwa-banner" style="background:var(--amber-light);border-color:var(--amber);color:var(--amber);">
      ⚠️ 本機模式：請在 <code>src/app.js</code> 填入 Firebase 設定，即可多人共用資料。</div>`:''}
    <div class="stat-grid">
      <div class="stat-card"><div class="stat-label">全部單據</div><div class="stat-value">${f.length}</div></div>
      <div class="stat-card"><div class="stat-label">草稿</div><div class="stat-value" style="color:var(--gray)">${f.filter(x=>x.status==='draft').length}</div></div>
      <div class="stat-card"><div class="stat-label">審核中</div><div class="stat-value" style="color:var(--amber)">${pend.length}</div></div>
      <div class="stat-card"><div class="stat-label">已核准</div><div class="stat-value" style="color:var(--green)">${f.filter(x=>x.status==='approved').length}</div></div>
    </div>
    ${pend.length?`<div class="card"><div class="card-title">待簽核 (${pend.length})</div>
      <div class="table-wrap"><table><thead><tr><th>序號</th><th>申請人</th><th>部門</th><th>日期</th><th></th></tr></thead>
      <tbody>${pend.map(f=>{const d=S.depts.find(d=>d.id===f.deptId)||{};return`<tr onclick="goForm('${f.id}')">
        <td class="td-mono">${f.seq}</td><td>${f.applicant}</td>
        <td><span class="badge badge-blue">${d.name||''}</span></td>
        <td class="text-muted text-xs">${f.date}</td>
        <td><button class="btn btn-sm btn-primary" onclick="event.stopPropagation();goApprove('${f.id}')">審核</button></td>
      </tr>`;}).join('')}</tbody></table></div></div>`:''}
    <div class="card"><div class="card-title">最近單據</div>
      <div class="table-wrap"><table><thead><tr><th>序號</th><th>申請人</th><th>狀態</th><th>日期</th></tr></thead>
      <tbody>${recent.map(f=>`<tr onclick="goForm('${f.id}')">
        <td class="td-mono">${f.seq}</td><td>${f.applicant}</td>
        <td><span class="badge ${statusCls(f.status)}">${statusLabel(f.status)}</span></td>
        <td class="text-muted text-xs">${f.date}</td>
      </tr>`).join('')}</tbody></table></div></div>
  </div>`;
}

function pgList() {
  let forms = S.forms;
  if (S.deptFilter) forms = forms.filter(f=>f.deptId===S.deptFilter);
  if (S.statusFilter) forms = forms.filter(f=>f.status===S.statusFilter);
  if (S.searchQ) { const q=S.searchQ.toLowerCase(); forms=forms.filter(f=>f.seq?.toLowerCase().includes(q)||f.applicant?.includes(q)||Object.values(f.fields||{}).some(v=>String(v).toLowerCase().includes(q))); }
  const dept = S.depts.find(d=>d.id===S.deptFilter);
  return `<div>
    <div class="page-header">
      <h1 class="page-title">${dept?dept.name+'表單':'全部表單'}</h1>
      <div style="margin-left:auto;"><button class="btn btn-primary" onclick="go('new-form')">+ 新增申請單</button></div>
    </div>
    <div class="toolbar">
      <div class="search-box"><span class="search-icon">🔍</span>
        <input type="text" placeholder="搜尋序號、申請人..." value="${S.searchQ}" oninput="S.searchQ=this.value;render()" style="padding-left:30px;width:190px;"></div>
      <select onchange="S.statusFilter=this.value;render()" style="font-size:13px;">
        <option value="">全部狀態</option>
        <option value="draft"${S.statusFilter==='draft'?' selected':''}>草稿</option>
        <option value="pending"${S.statusFilter==='pending'?' selected':''}>審核中</option>
        <option value="approved"${S.statusFilter==='approved'?' selected':''}>已核准</option>
        <option value="rejected"${S.statusFilter==='rejected'?' selected':''}>已退回</option>
      </select>
      ${!S.deptFilter?`<select onchange="S.deptFilter=this.value||null;render()" style="font-size:13px;">
        <option value="">全部部門</option>
        ${S.depts.map(d=>`<option value="${d.id}"${S.deptFilter===d.id?' selected':''}>${d.name}</option>`).join('')}
      </select>`:''}
    </div>
    ${forms.length===0?`<div class="empty-state"><div class="empty-icon">📭</div>沒有符合的表單</div>`:`
    <div class="table-wrap"><table>
      <thead><tr><th>序號</th><th>版本</th><th>申請人</th><th>部門</th><th>狀態</th><th>日期</th><th></th></tr></thead>
      <tbody>${forms.map(f=>{const d=S.depts.find(d=>d.id===f.deptId)||{};return`<tr onclick="goForm('${f.id}')">
        <td class="td-mono">${f.seq}</td>
        <td><span class="badge badge-draft">v${f.ver||1}</span></td>
        <td>${f.applicant}</td>
        <td><span class="badge badge-blue">${d.name||''}</span></td>
        <td><span class="badge ${statusCls(f.status)}">${statusLabel(f.status)}</span></td>
        <td class="text-muted text-xs">${f.date}</td>
        <td><button class="btn btn-sm" onclick="event.stopPropagation();goForm('${f.id}')">查看</button></td>
      </tr>`;}).join('')}</tbody>
    </table></div>`}
  </div>`;
}

function pgView() {
  const f = S.forms.find(x=>x.id===S.formId);
  if (!f) return `<div class="empty-state">找不到表單</div>`;
  const dept = S.depts.find(d=>d.id===f.deptId)||{};
  const flowDef = S.flows[f.deptId]||[];
  const acts = [];
  if (f.status==='draft'||f.status==='rejected') acts.push(`<button class="btn" onclick="go('edit-form')">編輯修訂</button>`);
  if (f.status==='draft') acts.push(`<button class="btn btn-primary" onclick="doReview('${f.id}')">送出審核</button>`);
  if (f.status==='pending') acts.push(`<button class="btn btn-primary" onclick="goApprove('${f.id}')">核准 / 退回</button>`);
  return `<div>
    <div class="page-header">
      <span class="page-back" onclick="goDept(S.deptFilter)">← 返回</span>
      <h1 class="page-title" style="font-family:monospace;font-size:16px;">${f.seq}</h1>
      <span class="badge ${statusCls(f.status)}" style="margin-left:8px;">${statusLabel(f.status)}</span>
    </div>
    ${acts.length?`<div class="flex gap-2 mb-2" style="flex-wrap:wrap;">${acts.join('')}</div>`:''}
    <div class="card"><div class="card-title">基本資料</div>
      <div class="form-grid">
        <span class="flabel">序號</span><div><span class="seq-badge">${f.seq}</span></div>
        <span class="flabel">版本</span><span><span class="badge badge-blue">v${f.ver||1}</span></span>
        <span class="flabel">申請人</span><span>${f.applicant}</span>
        <span class="flabel">部門</span><span>${dept.name||''}</span>
        <span class="flabel">申請日期</span><span>${f.date}</span>
        ${(dept.fields||[]).map(fd=>`<span class="flabel">${fd.label}</span><span>${f.fields?.[fd.id]||'<span class="text-muted">—</span>'}</span>`).join('')}
      </div>
    </div>
    <div class="card"><div class="card-title">品項明細（子表單）</div>
      <div style="overflow-x:auto;"><table class="subtable">
        <thead><tr><th>品名</th><th>數量</th><th>單位</th><th>單價</th><th>小計</th></tr></thead>
        <tbody>${(f.items||[]).map(it=>`<tr><td>${it.name}</td><td>${it.qty}</td><td>${it.unit}</td><td>${fmt(it.price)}</td><td>${fmt(it.qty*it.price)}</td></tr>`).join('')}</tbody>
        <tfoot><tr><td colspan="4" style="text-align:right;padding:8px;font-size:13px;">合計</td><td style="font-weight:600;color:var(--blue);padding:8px;">${fmt(calcTotal(f.items))}</td></tr></tfoot>
      </table></div>
    </div>
    <div class="card"><div class="card-title">簽核流程</div>
      <div class="approval-steps">
        ${flowDef.length===0?'<div class="text-muted text-sm">此部門尚未設定簽核流程</div>':
          flowDef.map((step,i)=>{
            const ap=(f.approvals||[]).find(a=>a.step===i);
            const cls=ap?.status==='approved'?'done':ap?.status==='rejected'?'rejected':
              (f.status==='pending'&&(f.approvals||[]).filter(a=>a.status==='approved').length===i)?'active':'';
            return`<div class="approval-step">
              <div class="step-circle ${cls}">${ap?.status==='approved'?'✓':ap?.status==='rejected'?'✗':i+1}</div>
              <div class="step-info">
                <div class="step-name">${step.role}</div>
                <div class="step-meta">${ap?.name?ap.name+' · '+ap.time:'等待審核'}</div>
                ${ap?.comment?`<div class="step-comment">${ap.comment}</div>`:''}
              </div></div>`;}).join('')}
      </div>
    </div>
    <div class="card"><div class="card-title">修訂紀錄</div>
      ${[...(f.history||[])].reverse().map(h=>`<div class="rev-item">
        <div class="rev-meta"><span class="rev-ver">${h.ver}</span><span class="rev-who">${h.who} · ${h.time}</span></div>
        <div class="rev-changes">${h.changes.length===0?'<span class="text-muted text-xs">初次建立</span>':
          h.changes.map(c=>`<div class="rev-change"><span class="rev-field">${c.field}：</span><span class="rev-old">${c.old}</span> → <span class="rev-new">${c.new}</span></div>`).join('')}</div>
        <div class="rev-reason">原因：${h.reason}</div>
      </div>`).join('')}
    </div>
  </div>`;
}

