// ── Render ──
function render() {
  app.innerHTML = `
    ${topbar()}
    <div class="overlay${S.sidebar?' show':''}" onclick="S.sidebar=false;render()"></div>
    <div class="sidebar${S.sidebar?' open':''}">${sidebar()}</div>
    <div class="main">${S.loading ? loading() : page()}</div>
    ${mobileNav()}
    <div class="toast" id="toast"></div>
    ${S.modal ? modal() : ''}`;
  if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(()=>{});
  pwaBanner();
}

function loading() {
  return `<div class="empty-state" style="padding-top:80px;">
    <div style="font-size:32px;animation:spin 1s linear infinite;display:inline-block;">⟳</div>
    <div style="margin-top:12px;">連接雲端資料庫中...</div>
  </div><style>@keyframes spin{to{transform:rotate(360deg)}}</style>`;
}

function topbar() {
  const sync = firebaseReady
    ? `<span style="font-size:11px;padding:2px 8px;background:var(--green-light);color:var(--green);border-radius:99px;white-space:nowrap;">● 雲端同步</span>`
    : `<span style="font-size:11px;padding:2px 8px;background:var(--amber-light);color:var(--amber);border-radius:99px;white-space:nowrap;">○ 本機模式</span>`;
  return `<div class="topbar">
    <div class="flex items-center gap-2">
      <button class="btn btn-icon" onclick="S.sidebar=!S.sidebar;render()" style="border:none;background:none;">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <span class="topbar-logo">FormHub</span>${sync}
    </div>
    <button class="btn btn-sm btn-primary" onclick="go('new-form')">+ 新增</button>
  </div>`;
}

function sidebar() {
  const pend = S.forms.filter(f=>f.status==='pending').length;
  return `<div class="sidebar-section">
    <div class="sidebar-label">主選單</div>
    <div class="sidebar-item${S.page==='dashboard'?' active':''}" onclick="go('dashboard')"><span>📊</span> 總覽</div>
    <div class="sidebar-item${S.page==='all-forms'&&!S.deptFilter?' active':''}" onclick="goDept(null)">
      <span>📋</span> 全部表單
      ${pend>0?`<span class="badge badge-pending" style="margin-left:auto;font-size:10px;">${pend}</span>`:''}
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">部門</div>
    ${S.depts.map(d=>`<div class="sidebar-item${S.deptFilter===d.id&&S.page==='all-forms'?' active':''}" onclick="goDept('${d.id}')">
      <span class="sidebar-dot" style="background:var(--${d.color})"></span>${d.name}
      <span class="text-xs text-muted" style="margin-left:auto;">${S.forms.filter(f=>f.deptId===d.id).length}</span>
    </div>`).join('')}
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">設定</div>
    <div class="sidebar-item${S.page==='settings'?' active':''}" onclick="go('settings')"><span>⚙️</span> 表單與部門設定</div>
  </div>`;
}

function mobileNav() {
  return `<nav class="mobile-nav">
    <div class="mobile-nav-item${S.page==='dashboard'?' active':''}" onclick="go('dashboard')"><span class="mobile-nav-icon">📊</span>總覽</div>
    <div class="mobile-nav-item${S.page==='all-forms'?' active':''}" onclick="goDept(null)"><span class="mobile-nav-icon">📋</span>表單</div>
    <div class="mobile-nav-item" onclick="go('new-form')"><span class="mobile-nav-icon" style="font-size:26px;color:var(--blue);">＋</span>新增</div>
    <div class="mobile-nav-item${S.page==='settings'?' active':''}" onclick="go('settings')"><span class="mobile-nav-icon">⚙️</span>設定</div>
  </nav>`;
}

function page() {
  switch(S.page) {
    case 'dashboard': return pgDashboard();
    case 'all-forms': return pgList();
    case 'form-view': return pgView();
    case 'new-form':  return pgNew();
    case 'edit-form': return pgEdit();
    case 'approve':   return pgApprove();
    case 'settings':  return pgSettings();
    default: return pgDashboard();
  }
}

