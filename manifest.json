// ── Firebase SDK (從 CDN 載入，不需安裝) ──
let db, collection, doc, getDocs, getDoc, setDoc, addDoc, updateDoc, onSnapshot, query, orderBy;
let firebaseReady = false;

async function initFirebase() {
  try {
    const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js');
    const fs = await import('https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js');
    const app = initializeApp(FIREBASE_CONFIG);
    db = fs.getFirestore(app);
    ({ collection, doc, getDocs, getDoc, setDoc, addDoc, updateDoc, onSnapshot, query, orderBy } = fs);
    firebaseReady = true;
  } catch (e) {
    console.warn('Firebase 未設定，使用本機模式', e);
  }
}

// ── 本機備用 ──
const Local = {
  get: k => { try { return JSON.parse(localStorage.getItem('fh_'+k)); } catch { return null; } },
  set: (k, v) => localStorage.setItem('fh_'+k, JSON.stringify(v))
};

// ── 雲端資料層 ──
const Cloud = {
  async getForms() {
    if (!firebaseReady) return Local.get('forms') || [];
    try {
      const snap = await getDocs(query(collection(db,'forms'), orderBy('date','desc')));
      return snap.docs.map(d => ({ id: d.id, ...d.data() }));
    } catch { return Local.get('forms') || []; }
  },
  async saveForm(form) {
    const { id, ...data } = form;
    Local.set('forms', (() => {
      const arr = Local.get('forms') || [];
      const i = arr.findIndex(f => f.id === id);
      if (i >= 0) arr[i] = form; else arr.push(form);
      return arr;
    })());
    if (!firebaseReady) return form;
    try {
      if (id && !id.startsWith('f_local_')) {
        await setDoc(doc(db,'forms',id), data);
        return form;
      } else {
        const ref = await addDoc(collection(db,'forms'), data);
        return { ...form, id: ref.id };
      }
    } catch (e) { console.error(e); return form; }
  },
  async getConfig(key) {
    if (!firebaseReady) return Local.get(key);
    try {
      const snap = await getDoc(doc(db,'config',key));
      return snap.exists() ? snap.data() : Local.get(key);
    } catch { return Local.get(key); }
  },
  async saveConfig(key, val) {
    Local.set(key, val);
    if (!firebaseReady) return;
    try { await setDoc(doc(db,'config',key), typeof val === 'object' && !Array.isArray(val) ? val : { _val: val }); }
    catch (e) { console.error(e); }
  },
  async getDepts() {
    const raw = await this.getConfig('depts');
    return Array.isArray(raw) ? raw : raw?._val || raw?.list || getDefaultDepts();
  },
  async saveDepts(d) {
    Local.set('depts', d);
    if (!firebaseReady) return;
    try { await setDoc(doc(db,'config','depts'), { list: d }); } catch {}
  },
  async getFlows() {
    const raw = await this.getConfig('flows');
    return raw && !raw._val ? raw : getDefaultFlows();
  },
  async saveFlows(f) {
    Local.set('flows', f);
    if (!firebaseReady) return;
    try { await setDoc(doc(db,'config','flows'), f); } catch {}
  },
  async getCounters() {
    const raw = await this.getConfig('counters');
    return raw && !raw._val ? raw : {};
  },
  async saveCounters(c) {
    Local.set('counters', c);
    if (!firebaseReady) return;
    try { await setDoc(doc(db,'config','counters'), c); } catch {}
  }
};

// ── State ──
const S = {
  page: 'dashboard', deptFilter: null, formId: null,
  modal: null, sidebar: false, searchQ: '', statusFilter: '',
  forms: [], depts: [], flows: {}, loading: true
};

// ── Helpers ──
const fmt = n => 'NT$ ' + Math.round(Number(n)||0).toLocaleString();
const pad = n => String(n).padStart(3,'0');
const now = () => new Date().toLocaleString('zh-TW',{hour12:false});
const today = () => new Date().toISOString().slice(0,10);
const calcTotal = items => (items||[]).reduce((s,i)=>s+(Number(i.qty)||0)*(Number(i.price)||0),0);
const statusLabel = s => ({draft:'草稿',pending:'審核中',approved:'已核准',rejected:'已退回'}[s]||s);
const statusCls   = s => ({draft:'badge-draft',pending:'badge-pending',approved:'badge-approved',rejected:'badge-rejected'}[s]||'badge-draft');

async function genSeq(deptId) {
  const c = await Cloud.getCounters();
  const n = c[deptId] || 1;
  c[deptId] = n + 1;
  await Cloud.saveCounters(c);
  return `${deptId}-${new Date().getFullYear()}-${pad(n)}`;
}

